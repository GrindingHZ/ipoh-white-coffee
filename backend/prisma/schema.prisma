generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  name                 String
  language             String
  locality             String
  homeJetty            String?
  fuelCapacity         Decimal?  @db.Decimal
  targetSpecies        String[]
  typicalDepartureTime String?
  createdAt            DateTime  @default(now())
  icNumber             String?   @unique
  sessions             AuthSession[]

  @@map("users")
}

model AuthSession {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  lastUsedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model TideEntry {
  id         String   @id @default(uuid()) @db.Uuid
  district   String
  date       DateTime @db.Date
  highTime   String?
  highHeight Decimal? @db.Decimal
  lowTime    String?
  lowHeight  Decimal? @db.Decimal

  @@unique([district, date])
  @@map("tide_entries")
}

model FuelPrice {
  id                     String   @id @default(uuid()) @db.Uuid
  effectiveDate          DateTime @db.Date @unique
  ron95Price             Decimal  @db.Decimal
  ron95UnsubsidisedPrice Decimal? @db.Decimal
  dieselPrice            Decimal  @db.Decimal
  dieselEastMsiaPrice    Decimal? @db.Decimal

  @@map("fuel_prices")
}

model SeasonalPattern {
  id            String  @id @default(uuid()) @db.Uuid
  species       String
  month         Int
  district      String
  activityLevel String
  notes         String?

  @@unique([species, month, district])
  @@map("seasonal_patterns")
}

model FishLanding {
  id         String   @id @default(uuid()) @db.Uuid
  date       DateTime @db.Date
  coast      String
  state      String
  landingsKg Int

  @@unique([date, coast, state])
  @@map("fish_landings")
}

model FishPrice {
  id              String   @id @default(uuid()) @db.Uuid
  weekLabel       String
  approxWeekStart DateTime @db.Date
  year            Int
  monthAbbr       String
  weekInMonth     Int
  speciesMalay    String
  speciesEnglish  String
  wholesaleRmKg   Decimal  @db.Decimal
  retailRmKg      Decimal  @db.Decimal
  reportSource    String

  @@unique([weekLabel, speciesMalay])
  @@map("fish_prices")
}

model MarinePrice {
  id                   String  @id @default(uuid()) @db.Uuid
  priceType            String
  speciesMalay         String
  month                Int
  monthNameMs          String
  priceRmPerKg         Decimal @db.Decimal
  annualAverageRmPerKg Decimal @db.Decimal

  @@unique([priceType, speciesMalay, month])
  @@map("marine_prices")
}

model MarineLandingStateMonthly {
  id             String  @id @default(uuid()) @db.Uuid
  coast          String
  state          String
  month          Int
  monthNameMs    String
  landingsTonnes Decimal @db.Decimal

  @@unique([coast, state, month])
  @@map("marine_landings_state_monthly")
}

model MarineLandingSpeciesMonthly {
  id             String  @id @default(uuid()) @db.Uuid
  speciesMalay   String
  month          Int
  monthNameMs    String
  landingsTonnes Decimal @db.Decimal

  @@unique([speciesMalay, month])
  @@map("marine_landings_species_monthly")
}

model FishingEffortStateTotal {
  id           String @id @default(uuid()) @db.Uuid
  coast        String
  state        String
  effortMetric String
  value        Int

  @@unique([coast, state, effortMetric])
  @@map("fishing_effort_state_totals")
}

model WeatherCache {
  id        String   @id @default(uuid()) @db.Uuid
  district  String
  type      String
  fetchedAt DateTime @default(now())
  payload   Json

  @@unique([type, district])
  @@map("weather_cache")
}
